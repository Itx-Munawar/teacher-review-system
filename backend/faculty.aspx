            elements.menu.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') { e.preventDefault(); playClickSound(); elements.menu.classList.add('close'); elements.menu.setAttribute('aria-hidden', 'true'); elements.icon.focus(); }
            });

            document.addEventListener('click', function (e) {
                var clickedInsideMenu = elements.menu.contains(e.target);
                var clickedOnIcon = elements.icon.contains(e.target);
                var clickedOnWrapper = elements.wrapper && elements.wrapper.contains(e.target);
                var clickedOnSkipLink = elements.skipLink && elements.skipLink.contains(e.target);

                if (state.ttsEnabled && !clickedInsideMenu && !clickedOnIcon && !clickedOnWrapper && !clickedOnSkipLink) { return; }
