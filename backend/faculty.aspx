        function init() {
            speakHandler = null;
            cacheElements();
            loadState();
            applyState();
            bindEvents();
            checkFeatureSupport();
            setupSkipLink();
            setupLanguageSelector();
        }

        function cacheElements() {
            elements = {
                wrapper: document.getElementById('accessibilityWidgetWrapper'),
                icon: document.getElementById('accessibilityIcon'),
                menu: document.getElementById('accessibilityMenu'),
                closeBtn: document.getElementById('closeMenuBtn'),
                resetBtn: document.getElementById('resetMenuBtn'),
                body: document.body,
                html: document.documentElement,
                sttAlertBox: document.getElementById('sttAlertBox'),
                sttAlertText: document.getElementById('sttAlertText'),
                sttAlertClose: document.getElementById('sttAlertClose'),
                announcer: document.getElementById('_accessAnnouncer'),
                skipLink: document.getElementById('skipLink'),
                sttLanguageSelector: document.getElementById('sttLanguageSelector'),
                sttLanguageSelect: document.getElementById('sttLanguageSelect'),
                sttWordCount: document.getElementById('sttWordCount'),
                sttVolumeLevel: document.getElementById('sttVolumeLevel'),
                sttMicIcon: document.getElementById('sttMicIcon')
            };
        }

        function setupLanguageSelector() {
            if (elements.sttLanguageSelect) {
                elements.sttLanguageSelect.value = state.sttLanguage;
                elements.sttLanguageSelect.addEventListener('change', function (e) {
                    state.sttLanguage = e.target.value;
                    saveState();
                    announceStateChange('Language changed to ' + e.target.options[e.target.selectedIndex].text);
                    if (state.sttEnabled) {
                        // Restart STT with new language
                        var btn = elements.menu.querySelector('[data-access-action="speechToText"]');
                        toggleSTT(btn);
                        setTimeout(function () { toggleSTT(btn); }, 500);
                    }
                });
            }
        }

        function setupSkipLink() {
            if (elements.skipLink) {
                elements.skipLink.addEventListener('click', function (e) {
                    e.preventDefault();
                    playClickSound();
                    var mainContent = document.getElementById('mainContent') || document.querySelector('.container.body-content');
                    if (mainContent) {
                        mainContent.setAttribute('tabindex', '-1');
                        mainContent.focus();
                        announceStateChange('Skipped to main content');
                    }
                });
            }
        }

        function announceStateChange(message) {
            if (!elements.announcer) return;
            elements.announcer.textContent = '';
            setTimeout(function () { elements.announcer.textContent = 'Accessibility: ' + message; }, 100);
