                if ('SpeechSynthesisUtterance' in window && state.soundEnabled) {
                    var utterance = new SpeechSynthesisUtterance('');
                    utterance.volume = 0.1;
                    utterance.rate = 3;
                    window.speechSynthesis.speak(utterance);
                }
