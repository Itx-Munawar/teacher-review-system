                    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); playClickSound(); handleAction(this.getAttribute('data-access-action'), this); }
                    if (e.key === 'ArrowDown' || e.key === 'ArrowUp') { e.preventDefault(); playClickSound(); navigateMenuItems(e.key === 'ArrowDown' ? 1 : -1); }
