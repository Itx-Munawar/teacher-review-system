            highlightOption(btn);

            switch (action) {
                case 'increaseText':
                    announceOptionClick('Increase Text Size');
                    state.fontSize = Math.min(state.fontSize + 1, 24);
                    elements.body.style.fontSize = state.fontSize + 'px';
                    announceStateChange('Text size increased to ' + state.fontSize + ' pixels');
                    break;
                case 'decreaseText':
                    announceOptionClick('Decrease Text Size');
                    state.fontSize = Math.max(state.fontSize - 1, 12);
                    elements.body.style.fontSize = state.fontSize + 'px';
                    announceStateChange('Text size decreased to ' + state.fontSize + ' pixels');
                    break;
                case 'increaseTextSpacing':
                    announceOptionClick('Increase Text Spacing');
                    state.spacing = Math.min(state.spacing + 0.5, 5);
                    elements.body.style.letterSpacing = state.spacing + 'px';
                    announceStateChange('Text spacing increased');
                    break;
                case 'decreaseTextSpacing':
                    announceOptionClick('Decrease Text Spacing');
                    state.spacing = Math.max(state.spacing - 0.5, 0);
                    elements.body.style.letterSpacing = state.spacing + 'px';
                    announceStateChange('Text spacing decreased');
                    break;
                case 'invertColors':
                    announceOptionClick('Invert Colours');
                    state.invertColors = !state.invertColors;
                    elements.html.classList.toggle('access-invert', state.invertColors);
                    announceStateChange('High Contrast ' + (state.invertColors ? 'Enabled' : 'Disabled'));
                    break;
                case 'grayHues':
                    announceOptionClick('Grey Hues');
                    state.grayHues = !state.grayHues;
                    elements.html.classList.toggle('access-gray', state.grayHues);
                    announceStateChange('Grayscale ' + (state.grayHues ? 'Enabled' : 'Disabled'));
                    break;
                case 'underlineLinks':
                    announceOptionClick('Underline Links');
                    state.underlineLinks = !state.underlineLinks;
                    elements.body.classList.toggle('access-underline', state.underlineLinks);
                    announceStateChange('Link Underlining ' + (state.underlineLinks ? 'Enabled' : 'Disabled'));
                    break;
                case 'bigCursor':
                    announceOptionClick('Big Cursor');
                    state.bigCursor = !state.bigCursor;
                    elements.html.classList.toggle('access-bigCursor', state.bigCursor);
                    announceStateChange('Large Cursor ' + (state.bigCursor ? 'Enabled' : 'Disabled'));
                    break;
                case 'readingGuide':
                    announceOptionClick('Reading Guide');
                    toggleReadingGuide(btn);
                    return;
                case 'textToSpeech':
                    announceOptionClick('Text To Speech');
                    toggleTTS(btn);
                    return;
                case 'speechToText':
                    announceOptionClick('Speech To Text');
                    toggleSTT(btn);
                    return;
            }
            saveState();
        }

        function toggleReadingGuide(btn) {
            state.readingGuide = !state.readingGuide;
            if (state.readingGuide) {
                if (!elements.readingGuideBar) {
                    elements.readingGuideBar = document.createElement('div');
                    elements.readingGuideBar.id = 'readingGuideBar';
                    elements.readingGuideBar.className = 'access-reading-guide';
                    elements.readingGuideBar.setAttribute('aria-hidden', 'true');
                    elements.body.appendChild(elements.readingGuideBar);
