            if (elements.sttAlertClose) {
                elements.sttAlertClose.addEventListener('click', function () {
                    playClickSound();
                    if (state.sttEnabled) {
                        var btn = elements.menu.querySelector('[data-access-action="speechToText"]');
                        toggleSTT(btn);
                    }
                    hideSTTAlert();
