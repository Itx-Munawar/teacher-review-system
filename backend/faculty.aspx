    backdrop-filter: blur(10px);
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateX(-50%) translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }
}

._stt-alert-content {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
}

._stt-mic-container {
    position: relative;
    display: flex;
    align-items: center;
    gap: 8px;
}

._stt-alert-icon {
    font-size: 24px;
    animation: pulse 1.5s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.1); }
}

._stt-volume-meter {
    width: 40px;
    height: 4px;
    background: rgba(255,255,255,0.3);
    border-radius: 2px;
    overflow: hidden;
}

._stt-volume-level {
    height: 100%;
    width: 0%;
    background: #4CAF50;
    transition: width 0.05s linear;
    border-radius: 2px;
}

._stt-word-count {
    font-size: 12px;
    background: rgba(255,255,255,0.2);
    padding: 4px 8px;
    border-radius: 20px;
    font-family: monospace;
}

._stt-commands-hint {
    font-size: 10px;
    opacity: 0.7;
    margin-top: 8px;
    text-align: center;
    font-family: monospace;
}

._stt-alert-close {
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    font-size: 20px;
    cursor: pointer;
    padding: 4px 10px;
    border-radius: 20px;
    transition: all 0.2s;
}

._stt-alert-close:hover {
    background: #e74c3c;
    transform: scale(1.05);
}

/* Active input field highlight */
._access-stt-active input:focus,
._access-stt-active textarea:focus,
._access-stt-active [contenteditable="true"]:focus {
    border: 3px solid #ff9800 !important;
    background-color: #fff8e1 !important;
    box-shadow: 0 0 0 3px rgba(255,152,0,0.3) !important;
    transition: all 0.2s ease;
}

/* Image hover for TTS */
._access-tts-active img:hover {
    outline: 3px solid #ff9800 !important;
    filter: brightness(1.05);
    cursor: pointer;
}

._access-tts-active *:hover {
    box-shadow: 2px 2px 3px rgba(100,100,100,0.8)!important;
    cursor: pointer!important;
}

._access-tts-active #accessibilityIcon:hover,
._access-tts-active #accessibilityMenu:hover,
._access-tts-active ._access-icon:hover,
._access-tts-active ._access-menu:hover,
._access-tts-active ._access-skip-link:hover {
    box-shadow: none!important;
}
</style>

<script type="text/javascript">
    //<![CDATA[
    (function () {
        'use strict';

        // ===== STATE MANAGEMENT =====
        var state = {
            fontSize: 14,
            spacing: 0,
            invertColors: false,
            grayHues: false,
            underlineLinks: false,
            bigCursor: false,
            readingGuide: false,
            ttsEnabled: false,
            sttEnabled: false,
            soundEnabled: true,
            sttLanguage: 'en-US'
        };

        var elements = {};
        var recognition = null;
        var readingGuideCleanup = null;
        var speakHandler = null;
        var ttsStyleElement = null;
        var isListening = false;
        var currentTranscript = '';
        var volumeAnimationInterval = null;

        // ===== AUDIO FEEDBACK =====
        function playClickSound() {
            if (!state.soundEnabled) return;
            try {
                var AudioContext = window.AudioContext || window.webkitAudioContext;
                if (AudioContext) {
                    var ctx = new AudioContext();
                    var oscillator = ctx.createOscillator();
                    var gainNode = ctx.createGain();
                    oscillator.connect(gainNode);
                    gainNode.connect(ctx.destination);
                    oscillator.type = 'square';
                    oscillator.frequency.value = 1000;
                    gainNode.gain.value = 0.15;
                    oscillator.start();
                    oscillator.stop(ctx.currentTime + 0.06);
                    return;
                }
            } catch (e) { console.log('Web Audio beep failed:', e); }
