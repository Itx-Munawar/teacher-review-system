                elements.readingGuideBar.style.display = 'block';
                var moveGuide = function (e) {
                    var y = e.touches ? e.touches[0].clientY : e.clientY;
                    elements.readingGuideBar.style.top = (y - 6) + 'px';
                };
                document.addEventListener('mousemove', moveGuide);
                document.addEventListener('touchmove', moveGuide, { passive: true });
                readingGuideCleanup = function () {
                    document.removeEventListener('mousemove', moveGuide);
                    document.removeEventListener('touchmove', moveGuide);
                };
                announceStateChange('Reading guide enabled');
            } else {
                if (elements.readingGuideBar) elements.readingGuideBar.style.display = 'none';
                if (readingGuideCleanup) { readingGuideCleanup(); readingGuideCleanup = null; }
                announceStateChange('Reading guide disabled');
            }
            saveState();
        }

        // ===== TTS FUNCTION WITH IMAGE SUPPORT =====
        function toggleTTS(btn) {
            if (!('SpeechSynthesisUtterance' in window)) {
                btn.classList.add('not-supported');
                btn.setAttribute('aria-disabled', 'true');
                btn.title = 'Text-to-Speech not supported in this browser';
                announceStateChange('Text to Speech not supported');
                return;
            }

            state.ttsEnabled = !state.ttsEnabled;

            if (state.ttsEnabled) {
                addTTSHoverStyle();
                elements.body.classList.add('_access-tts-active');
                btn.classList.add('active');

                speakHandler = function (e) {
                    if (!state.ttsEnabled) return;

                    if (e.target.closest('#accessibilityMenu') ||
                        e.target.closest('#accessibilityIcon') ||
                        e.target.closest('._access-widget-wrapper') ||
                        e.target.closest('._access-skip-link')) return;

                    var text = '';
                    var target = e.target;

                    if (target.tagName === 'IMG') {
                        if (target.alt && target.alt.trim() !== '') {
                            text = 'Image: ' + target.alt;
                        } else if (target.title && target.title.trim() !== '') {
                            text = 'Image: ' + target.title;
                        } else if (target.getAttribute('aria-label')) {
                            text = 'Image: ' + target.getAttribute('aria-label');
                        } else {
                            text = 'Image with no description';
                        }
                    }
                    else if (target.querySelector && target.querySelector('img')) {
                        var img = target.querySelector('img');
                        if (img && img.alt && img.alt.trim() !== '') {
                            text = 'Image: ' + img.alt;
                        } else if (img && img.title) {
                            text = 'Image: ' + img.title;
                        }
                    }

                    if (!text || text.length < 2) {
                        text = target.innerText || target.textContent || '';
                        text = text.trim();
                    }

                    if ((!text || text.length < 2) && target.getAttribute('aria-label')) {
                        text = target.getAttribute('aria-label');
                    }

                    if (!text || text.length < 2) {
                        if (target.tagName === 'IMG') {
                            text = 'Image without alternative text';
                        } else {
                            text = target.tagName.toLowerCase() + ' element';
                        }
                    }

                    window.speechSynthesis.cancel();
                    try {
                        var utterance = new SpeechSynthesisUtterance(text);
                        utterance.lang = state.sttLanguage || 'en-US';
                        utterance.rate = 1;
                        utterance.pitch = 1;
                        utterance.volume = 0.9;
                        window.speechSynthesis.speak(utterance);
                    } catch (err) {
                        console.log('TTS error:', err);
                    }
                };

                document.addEventListener('click', speakHandler, true);
                announceStateChange('Text to Speech enabled. Click any text or image to hear it.');

            } else {
                removeTTSHoverStyle();
                elements.body.classList.remove('_access-tts-active');
                btn.classList.remove('active');
                window.speechSynthesis.cancel();
                if (speakHandler) { document.removeEventListener('click', speakHandler, true); speakHandler = null; }
                announceStateChange('Text to Speech disabled');
            }
            saveState();
        }

        function addTTSHoverStyle() {
            if (!ttsStyleElement) {
                ttsStyleElement = document.createElement('style');
                ttsStyleElement.className = '_access-text-to-speech';
                ttsStyleElement.textContent = '._access-tts-active *:hover{box-shadow:2px 2px 3px rgba(100,100,100,0.8)!important;cursor:pointer!important}._access-tts-active img:hover{outline:3px solid #ff9800!important;filter:brightness(1.05)}._access-tts-active #accessibilityIcon:hover,._access-tts-active #accessibilityMenu:hover,._access-tts-active ._access-icon:hover,._access-tts-active ._access-menu:hover,._access-tts-active ._access-skip-link:hover{box-shadow:none!important}';
                document.head.appendChild(ttsStyleElement);
            }
        }

        function removeTTSHoverStyle() {
            if (ttsStyleElement) { ttsStyleElement.remove(); ttsStyleElement = null; }
        }

        // ===== ENHANCED STT FUNCTION =====
        function processVoiceCommands(transcript) {
            var commands = {
                'period': '.',
                'dot': '.',
                'comma': ',',
                'question mark': '?',
                'question': '?',
                'exclamation mark': '!',
                'exclamation': '!',
                'new line': '\n',
                'new paragraph': '\n\n',
                'space': ' ',
                'stop listening': '___STOP___',
                'stop': '___STOP___'
            };

            var processed = transcript.toLowerCase();
            for (var cmd in commands) {
                if (processed.includes(cmd)) {
                    if (commands[cmd] === '___STOP___') {
                        return '___STOP___';
                    }
                    processed = processed.replace(new RegExp(cmd, 'gi'), commands[cmd]);
                }
            }
            return processed;
        }

        function updateWordCount(text) {
            if (elements.sttWordCount) {
                var words = text.trim().split(/\s+/).filter(function (w) { return w.length > 0; });
                elements.sttWordCount.textContent = words.length + ' word' + (words.length !== 1 ? 's' : '');
            }
        }

        function simulateVolumeMeter() {
            if (volumeAnimationInterval) clearInterval(volumeAnimationInterval);
            volumeAnimationInterval = setInterval(function () {
                if (elements.sttVolumeLevel && isListening) {
                    var randomVolume = Math.random() * 80 + 20;
                    elements.sttVolumeLevel.style.width = randomVolume + '%';
                    if (randomVolume > 60) {
                        elements.sttVolumeLevel.style.background = '#4CAF50';
                    } else if (randomVolume > 30) {
                        elements.sttVolumeLevel.style.background = '#FFC107';
                    } else {
                        elements.sttVolumeLevel.style.background = '#F44336';
                    }
                }
            }, 100);
        }

        function toggleSTT(btn) {
            var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            var isSecure = location.protocol === 'https:' || location.hostname === 'localhost' || location.hostname === '127.0.0.1';

            if (!SpeechRecognition) {
                btn.classList.add('not-supported');
                btn.setAttribute('aria-disabled', 'true');
                alert('Speech Recognition is not supported in your browser.\n\nPlease use Google Chrome, Edge, or Safari.');
                announceStateChange('Speech to Text not supported');
                return;
            }

            if (!isSecure) {
                btn.classList.add('not-supported');
                btn.setAttribute('aria-disabled', 'true');
                alert('Speech-to-Text requires HTTPS.\n\nFor local development, use localhost or enable HTTPS.');
                announceStateChange('Speech to Text requires HTTPS');
                return;
            }

            state.sttEnabled = !state.sttEnabled;

            if (state.sttEnabled) {
                try {
                    recognition = new SpeechRecognition();
                    recognition.continuous = true;
                    recognition.interimResults = true;
                    recognition.lang = state.sttLanguage || 'en-US';
                    recognition.maxAlternatives = 1;

                    showSTTAlert('🎤 Listening... Speak now');
                    announceStateChange('Speech to Text enabled - Language: ' + (elements.sttLanguageSelect ? elements.sttLanguageSelect.options[elements.sttLanguageSelect.selectedIndex].text : 'English'));

                    if (elements.sttLanguageSelector) {
                        elements.sttLanguageSelector.style.display = 'block';
                    }

                    document.body.classList.add('_access-stt-active');
                    isListening = true;
                    simulateVolumeMeter();

                    if (elements.sttMicIcon) {
                        elements.sttMicIcon.style.animation = 'pulse 1.5s infinite';
                    }

                    recognition.onstart = function () {
                        showSTTAlert('🎤 Listening... Speak clearly');
                        isListening = true;
                    };

                    recognition.onresult = function (event) {
                        var interimTranscript = '';
                        var finalTranscript = '';

                        for (var i = event.resultIndex; i < event.results.length; i++) {
                            var transcript = event.results[i][0].transcript;
                            if (event.results[i].isFinal) {
                                finalTranscript += transcript;
                            } else {
                                interimTranscript += transcript;
                            }
                        }

                        if (finalTranscript) {
                            var processed = processVoiceCommands(finalTranscript);
                            if (processed === '___STOP___') {
                                showSTTAlert('⏹️ Stopped listening');
                                toggleSTT(btn);
                                return;
                            }

                            currentTranscript = processed;
                            updateWordCount(currentTranscript);

                            var activeEl = document.activeElement;
                            var isInput = activeEl && (activeEl.tagName === 'INPUT' ||
                                activeEl.tagName === 'TEXTAREA' ||
                                activeEl.isContentEditable);

                            if (isInput) {
                                var currentValue = activeEl.value || '';
                                var cursorPos = activeEl.selectionStart || currentValue.length;
                                var newValue = currentValue.slice(0, cursorPos) + processed + ' ' + currentValue.slice(cursorPos);
                                activeEl.value = newValue;
                                var newCursorPos = cursorPos + processed.length + 1;
                                activeEl.setSelectionRange(newCursorPos, newCursorPos);
                                var inputEvent = new Event('input', { bubbles: true });
                                activeEl.dispatchEvent(inputEvent);
                                showSTTAlert('✅ ' + processed.substring(0, 50) + (processed.length > 50 ? '...' : ''));
                            } else {
                                navigator.clipboard.writeText(processed).then(function () {
                                    showSTTAlert('📋 Copied: ' + processed.substring(0, 50));
                                    announceStateChange('Text copied to clipboard');
                                });
                            }
                        } else if (interimTranscript) {
                            showSTTAlert('🎤 ' + interimTranscript + ' (listening...)');
